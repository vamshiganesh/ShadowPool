{
  "name": "@shadowpool/matcher",
  "version": "1.0.0",
  "private": true,
  "description": "ShadowPool automated matcher, prover, and settlement relay service",
  "main": "dist/index.js",
  "scripts": {
    "build:prover": "cd ../../prover && npm install && npm run build",
    "build": "tsc",
    "build:all": "npm run build:prover && npm run build",
    "start": "node dist/index.js",
    "dev": "ts-node --project tsconfig.json src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@supabase/supabase-js": "^2.50.0",
    "dotenv": "^16.5.0",
    "ethers": "^6.15.0",
    "fastify": "^4.29.0",
    "pino-pretty": "^13.1.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.3"
  }
}
